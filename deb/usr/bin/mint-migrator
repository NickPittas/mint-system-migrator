#!/bin/bash
# Launcher script for mint-system-migrator

APP_DIR="/usr/share/mint-migrator"
VENV_DIR="$APP_DIR/venv"

# Check if venv exists, if not create it
if [ ! -d "$VENV_DIR" ]; then
    echo "Setting up Mint System Migrator for first run..."
    python3 -m venv "$VENV_DIR"
    source "$VENV_DIR/bin/activate"
    pip install --quiet PyQt6
fi

# Activate and run
source "$VENV_DIR/bin/activate"
cd "$APP_DIR"
python3 src/gui.py "$@"
